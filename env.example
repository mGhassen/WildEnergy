# Copy to .env and fill in values. Do not commit .env.

# App
# NEXT_PUBLIC_ENV=development
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_ENV=production
# NEXT_PUBLIC_SITE_URL=https://wildenergy.vercel.app

# Supabase Database Configuration (placeholders only)
######### Remote
# NEXT_PUBLIC_SUPABASE_URL=YOUR_REMOTE_SUPABASE_URL
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_REMOTE_SUPABASE_ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY=YOUR_REMOTE_SUPABASE_SERVICE_ROLE_KEY

######### Local
# NEXT_PUBLIC_SUPABASE_URL=YOUR_LOCAL_SUPABASE_URL
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_LOCAL_SUPABASE_ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY=YOUR_LOCAL_SUPABASE_SERVICE_ROLE_KEY

# Google OAuth (Google Cloud Console → APIs & Services → Credentials)
# GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
# GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
# GOOGLE_CALLBACK_URL=YOUR_GOOGLE_CALLBACK_URL

# Optional: cron auth (for /api/cron/*)
CRON_SECRET=

# Optional: locale/currency (defaults in code)
# NEXT_PUBLIC_CURRENCY_CODE=TND
# NEXT_PUBLIC_CURRENCY_SYMBOL=TND
# NEXT_PUBLIC_CURRENCY_LOCALE=fr-FR
# NEXT_PUBLIC_DATE_LOCALE=fr-FR
# NEXT_PUBLIC_TIME_LOCALE=fr-FR
# NEXT_PUBLIC_TIMEZONE=Africa/Tunis



